digraph techtree {
    graph [
        rankdir = TB
        fontname = "Helvetica"
        fontsize = 11
        splines = ortho
        nodesep = 0.4
        ranksep = 0.7
        label = "Starscape 5 — Tech Tree\nDomain prerequisite DAG"
        labelloc = t
    ]
    node [fontname="Helvetica" fontsize=10 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=9]

    /* ── POWER DOMAIN ─────────────────────────────────────────────── */
    subgraph cluster_PWR {
        label="Power Domain (0–8)"
        style=filled fillcolor="#fff9e6" color="#c8a000"
        node [fillcolor="#ffeea0"]
        P1 [label="P-1\nChemical / fission"]
        P2 [label="P-2\nFusion (practical)"]
        P3 [label="P-3\nFusion (high-density)"]
        P4 [label="P-4\nAntimatter / exotic tap"]
        P1 -> P2 -> P3 -> P4
    }

    /* ── MATERIALS DOMAIN ─────────────────────────────────────────── */
    subgraph cluster_MAT {
        label="Materials Domain (0–8)"
        style=filled fillcolor="#f0f5ff" color="#3060c0"
        node [fillcolor="#c8d8ff"]
        M1 [label="M-1\nIndustrial alloys / composites"]
        M2 [label="M-2\nNanostructured materials"]
        M3 [label="M-3\nExotic matter detection & handling"]
        M4 [label="M-4\nActive exotic matter production"]
        M1 -> M2 -> M3 -> M4
    }

    /* ── COMPUTING / INFORMATION DOMAIN ───────────────────────────── */
    subgraph cluster_CMP {
        label="Computing / Information Domain (0–8)"
        style=filled fillcolor="#f0fff0" color="#208020"
        node [fillcolor="#b8f0b8"]
        C1 [label="C-1\nDigital networks / basic AI"]
        C2 [label="C-2\nHigh-bandwidth sensors / nav AI"]
        C3 [label="C-3\nPredictive nav / quantum comm"]
        C5 [label="C-5\nSubstrate-independent cognition"]
        C1 -> C2 -> C3 -> C5
    }

    /* ── LIFE SUPPORT / HABITAT DOMAIN ───────────────────────────── */
    subgraph cluster_LSH {
        label="Life Support / Habitat Domain (0–8)"
        style=filled fillcolor="#fff0f8" color="#a03080"
        node [fillcolor="#f0c0e0"]
        L1 [label="L-1\nClosed-loop life support"]
        L2 [label="L-2\nLong-duration cryo / generation ship"]
        L3 [label="L-3\nDirected terraforming"]
        L4 [label="L-4\nFull planetary engineering"]
        L1 -> L2 -> L3 -> L4
    }

    /* ── BIOTECH DOMAIN ───────────────────────────────────────────── */
    subgraph cluster_BIO {
        label="Biotech Domain (0–8)"
        style=filled fillcolor="#fff4f0" color="#c03000"
        node [fillcolor="#ffd0b8"]
        B1 [label="B-1\nAdvanced medicine / gene therapy"]
        B2 [label="B-2\nSomatic augmentation & implants"]
        B3 [label="B-3\nPerformance augmentation (military)"]
        B4 [label="B-4\nGermline engineering (heritable)"]
        B6 [label="B-6\nNeural interface / consciousness substrate"]
        B1 -> B2 -> B3
        B2 -> B4 -> B6
    }

    /* ── PROPULSION DOMAIN ────────────────────────────────────────── */
    subgraph cluster_PRO {
        label="Propulsion Domain (0–8)"
        style=filled fillcolor="#f5f0ff" color="#6030c0"
        node [fillcolor="#d8c8ff"]
        PR1 [label="PR-1\nOrbital rockets"]
        PR2 [label="PR-2\nIn-system drive\n(weeks between planets)"]
        PR3 [label="PR-3\nHigh-thrust in-system / sublight"]
        PR4 [label="PR-4\nRelativistic drives"]
        PR1 -> PR2 -> PR3 -> PR4
    }

    /* ── MILESTONE NODES ─────────────────────────────────────────── */
    node [shape=diamond style="filled,bold" fillcolor="#d0f0d0" color="#107010" fontsize=11]
    ORB [label="Orbital\nCapability"]
    SBT [label="Space-Based\nTelescopes"]
    IPS [label="Interplanetary\nTravel"]
    ISL [label="Interstellar\nSublight"]
    FTP [label="FTL Precursor\n(exotic matter theory)"]

    /* ── JUMP DRIVE NODES ────────────────────────────────────────── */
    subgraph cluster_JMP {
        label="Jump Drive (split tracks)"
        style=filled fillcolor="#e8e8ff" color="#404080"
        node [shape=box style="filled,bold" fillcolor="#b0b0ff" fontsize=10]
        JR1  [label="Jump Range-1\n(1 pc)"]
        JR3  [label="Jump Range-3\n(3 pc)"]
        JT_SLOW [label="Transit: 3 weeks"]
        JT_FAST [label="Transit: 5 days"]
        JR1 -> JR3
        JR1 -> JT_SLOW -> JT_FAST
    }

    /* ── PREREQUISITE CROSS-EDGES ────────────────────────────────── */

    /* Orbital */
    P1  -> ORB
    M1  -> ORB
    PR1 -> ORB
    ORB -> SBT
    C1  -> SBT

    /* Interplanetary */
    P2  -> IPS
    PR2 -> IPS
    L1  -> IPS

    /* Interstellar sublight */
    IPS -> ISL
    P3  -> ISL
    PR3 -> ISL
    M2  -> ISL
    L2  -> ISL
    C2  -> ISL

    /* FTL precursor */
    M3 -> FTP
    C3 -> FTP

    /* Jump range */
    FTP -> JR1
    P4  -> JR1
    M4  -> JR1
    P4  -> JR3
    M4  -> JR3

    /* Jump transit */
    C3 -> JT_FAST

    /* Biotech cross-prereqs */
    C1 -> B1
    L1 -> B1
    C2 -> B2
    L3 -> B4
    C5 -> B6

    /* ── NOTES (invisible; for documentation) ────────────────────
        Species modifiers (see species.md — not modelled as edges):
          adaptability        → rate of advancement per domain
          hierarchy_tolerance → who in the polity receives biotech
          social_cohesion     → B4 germline fork destabilisation risk
          faction_tendency    → parallel-track divergence in high-faction species

        Kraathi  : open-volume ship multiplier on all PRO/LSH costs
        Nakhavi  : orbital habitats cheaper than planetary; BIO follows inward path
        Nhaveth  : tech advances via court competition (polity-level, not species)
        Kreeth   : no foreign tech adoption; single forced path; no internal competition
        Vrekkai  : B4 germline event is a civilisation-defining simulation trigger
        Vardhek  : B-tier (esp. B6) treated as strategic intelligence asset

        Jump range  → driven by Power + Materials
        Jump transit → driven by Computing
        These are separate investment tracks within the Propulsion domain
    ─────────────────────────────────────────────────────────────── */
}
